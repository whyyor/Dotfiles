{
  "$schema": "https://opencode.ai/config.json",
  "model": "anthropic/claude-opus-4-7",
  "mode": {
    "build": {
      "prompt": "You are opencode"
    }
  },
  "plugin": ["@ex-machina/opencode-anthropic-auth@latest"],
  "mcp": {
    "outlook": {
      "type": "local",
      "command": [
        "node",
        "{env:HOME}/Wiki/outlook-mcp/index.js",
        "node",
        "{env:HOME}/Wiki/outlook-mcp/outlook-auth-server.js"
      ],
      "environment": {
        "MS_CLIENT_ID": "{env:MS_CLIENT_ID}",
        "MS_CLIENT_SECRET": "{env:MS_CLIENT_SECRET}",
        "OUTLOOK_CLIENT_ID": "{env:OUTLOOK_CLIENT_ID}",
        "OUTLOOK_CLIENT_SECRET": "{env:OUTLOOK_CLIENT_SECRET}"
      },
      "enabled": false
    },
    "beeper": {
      "type": "remote",
      "url": "http://localhost:23373/v0/mcp",
      "headers": {
        "Authorization": "Bearer {env:BEEPER_TOKEN}"
      },
      "enabled": false
    },
    "github": {
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {env:GIT_TOKEN}"
      },
      "enabled": false
    }
  }
}
